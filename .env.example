# ── Environment ───────────────────────────────────────────────────────────────
APP_ENV=dev

# ── Local storage ───────────────────────────────────────────────────────────────
# SQLite file for sites/runs and a folder for generated images. Defaults are fine.
DB_PATH=blogsmith.db
IMAGES_DIR=media

# ── API keys (single local workspace) ───────────────────────────────────────────
# Required to generate posts + images:
GEMINI_API_KEY=
# Optional:
# LANGSMITH_API_KEY=
LANGSMITH_PROJECT=blogsmith
# SERP_API_KEY=

# ── LLM ───────────────────────────────────────────────────────────────────────────
TEXT_MODEL=gemini-2.0-flash
IMAGE_MODEL=gemini-2.0-flash-exp-image-generation
LLM_RUN_BUDGET=60

# ── Scheduler (in-process) ──────────────────────────────────────────────────────
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_SECONDS=60
