# ── Environment ───────────────────────────────────────────────────────────────
APP_ENV=dev

# ── Local storage ───────────────────────────────────────────────────────────────
# SQLite file for sites/runs and a folder for generated images. Defaults are fine.
DB_PATH=blogsmith.db
IMAGES_DIR=media

# ── API keys (single local workspace) ───────────────────────────────────────────
# Required to generate posts + images:
GEMINI_API_KEY=
# Optional:
# LANGSMITH_API_KEY=
LANGSMITH_PROJECT=blogsmith
# SERP_API_KEY=

# ── LLM ───────────────────────────────────────────────────────────────────────────
TEXT_MODEL=gemini-2.0-flash
IMAGE_MODEL=gemini-2.0-flash-exp-image-generation
LLM_RUN_BUDGET=60

# ── Concurrency ───────────────────────────────────────────────────────────────────
# How many blog runs may execute at the same time (guards Gemini rate limits).
MAX_CONCURRENT_RUNS=3

# ── Publishing (Field Notes API) ────────────────────────────────────────────────
# Push finished .mdx posts straight to your site. Off by default.
PUBLISH_ENABLED=false
FIELD_NOTES_URL=https://tessera-web-qilhoreu6q-el.a.run.app/api/field-notes
# Bearer token for the Field Notes API (ask the site owner). Required when enabled.
FIELD_NOTES_TOKEN=

# ── Scheduler (in-process) ──────────────────────────────────────────────────────
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_SECONDS=60
