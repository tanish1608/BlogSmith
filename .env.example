# ── Environment ───────────────────────────────────────────────────────────────
APP_ENV=dev

# ── Auth (dev convenience) ──────────────────────────────────────────────────────
# Skip Firebase ID-token verification locally. NEVER set true in prod.
AUTH_DISABLED=true
DEV_UID=dev-user
DEV_EMAIL=you@example.com

# ── Firebase ─────────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=blogsmith-local
FIREBASE_STORAGE_BUCKET=blogsmith-local.appspot.com
# Set automatically by `firebase emulators:start`; uncomment to force.
# FIRESTORE_EMULATOR_HOST=localhost:8080
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
# STORAGE_EMULATOR_HOST=http://localhost:9199
# Prod only: path to service-account JSON.
# GOOGLE_APPLICATION_CREDENTIALS=/secrets/sa.json

# ── Crypto ─────────────────────────────────────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# KEY_ENCRYPTION_KEY=

# ── LLM ───────────────────────────────────────────────────────────────────────────
TEXT_MODEL=gemini-2.0-flash
IMAGE_MODEL=gemini-2.0-flash-exp-image-generation
LLM_RUN_BUDGET=60
# Local-only fallback Gemini key (real users bring their own via /account).
# FALLBACK_GEMINI_KEY=

# ── LangSmith (optional) ──────────────────────────────────────────────────────────
# LANGSMITH_API_KEY=
LANGSMITH_PROJECT=blogsmith

# ── Dispatch / scheduler ───────────────────────────────────────────────────────────
DISPATCH_TO_CLOUD_RUN=false
CLOUD_RUN_JOB_NAME=blogsmith-job
CLOUD_RUN_REGION=us-central1
SCHEDULER_SECRET=change-me-in-prod
